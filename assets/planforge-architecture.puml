@startuml
title PlanForge Codebase Overview

left to right direction
skinparam shadowing false
skinparam packageStyle rectangle
skinparam componentStyle rectangle
skinparam ArrowColor #5B6470
skinparam PackageBorderColor #5B6470
skinparam PackageFontColor #1F2933
skinparam ComponentBorderColor #5B6470
skinparam ComponentFontColor #1F2933
skinparam DatabaseBorderColor #5B6470
skinparam DatabaseFontColor #1F2933
skinparam NoteBorderColor #8C94A3

actor "Clients\nWeb / Telegram / Twilio" as Clients

package "FastAPI App\nserver/main.py" as App {
  package "API Routers\nserver/app/api" as Api {
    [message.py] as MessageApi
    [calendar.py] as CalendarApi
    [tasks.py] as TasksApi
    [prefs.py] as PrefsApi
    [policies.py] as PoliciesApi
    [ops.py] as OpsApi
  }

  package "Auth + Config" as AuthConfig {
    [google_oauth.py] as Auth
    [config.py] as Config
  }

  package "Planning + Execution Services\nserver/app/services" as Services {
    [IngressContextService] as Ingress
    [AgentWorkflowService] as Workflows
    [LLMRouter] as Router
    [ToolHost] as ToolHost
    [SandboxExecutor] as SandboxExec
    [SandboxRuntimeClient] as RuntimeClient
    [FreeBusyService] as FreeBusy
    [GCalClient] as GCalClient
    [TasksService] as TasksService
    [PolicyStore] as PolicyStore
    [ReorgService] as ReorgService
    [ChangeLogger] as ChangeLogger
    [calendar_projection.py] as Projection
  }

  package "LLM Contract\nserver/app/llm_contract" as Contract {
    [system_prompt.md] as SystemPrompt
    [tool_schemas.json] as ToolSchemas
    [tools_manifest.md] as ToolsManifest
  }

  package "Models + Persistence" as Persistence {
    [SQLAlchemy Models\nuser / prefs / policy / changelog] as Models
    [Alembic Migrations] as Alembic
    database "SQLite / DATABASE_URL" as Database
  }
}

package "Sandbox Sidecar\nsandbox/quickjs" as SandboxSidecar {
  [runner.js] as Runner
  [plan_runtime.js] as PlanRuntime
}

package "Eval Harness\n./evals" as Evals {
  [runner.py] as EvalRunner
  [adapters/*] as EvalAdapters
  [cases/*] as EvalCases
  [baseline.py] as EvalBaseline
  [reports/*] as EvalReports
}

[.github/workflows/evals.yml] as EvalCI

cloud "OpenAI API" as OpenAI
cloud "Google Calendar API" as GoogleCalendar

Clients --> MessageApi : scheduling requests
Clients --> CalendarApi
Clients --> TasksApi
Clients --> PrefsApi
Clients --> PoliciesApi
Clients --> OpsApi

MessageApi --> Auth
CalendarApi --> Auth
TasksApi --> Auth
PrefsApi --> Auth
PoliciesApi --> Auth
OpsApi --> Auth

App --> Config
App --> MessageApi
App --> CalendarApi
App --> TasksApi
App --> PrefsApi
App --> PoliciesApi
App --> OpsApi

MessageApi --> Ingress : build request context
MessageApi --> Router : process_message()
Ingress --> GCalClient
Ingress --> PolicyStore
Ingress --> FreeBusy

Router --> Workflows : classify request
Router --> Contract : load prompts + tool schemas
Router --> ToolHost : native tools
Router --> SandboxExec : sandbox plan execution
Router --> OpenAI : classify, plan, summarize

SandboxExec --> ToolHost : execute tool steps
SandboxExec --> RuntimeClient : quickjs_plan backend
RuntimeClient <--> Runner : NDJSON protocol
Runner --> PlanRuntime : execute plan
Runner --> ToolHost : host tool bridge

ToolHost --> GCalClient
ToolHost --> TasksService
ToolHost --> PolicyStore
ToolHost --> ReorgService
ToolHost --> ChangeLogger
ToolHost --> FreeBusy
ToolHost --> Projection

GCalClient --> GoogleCalendar
TasksService --> Database
PolicyStore --> Database
ChangeLogger --> Database
Models --> Database
Alembic --> Database

EvalRunner --> EvalAdapters
EvalRunner --> EvalCases
EvalRunner --> EvalReports
EvalBaseline --> EvalReports
EvalCI --> EvalRunner
EvalCI --> EvalBaseline

note bottom of Router
Classifies each request into a workflow,
restricts tool access, and records a
workflow trace for the response.
end note

note bottom of ToolHost
Single host-side boundary for calendar,
task, policy, preference, reorg,
and undo operations.
end note

note bottom of SandboxSidecar
QuickJS/WASM executes JSON plans while
calling back into Python through the
runtime client and ToolHost bridge.
end note

@enduml
