      "output_schema": {
        "type": "object",
        "properties": {
          "op_id": { "type": "string" },
          "event_id": { "type": "string" }
        }
      }
    },
    {
      "name": "calendar.update",
      "method": "POST",
      "endpoint": "/calendar/update",
      "input_schema": {
        "type": "object",
        "required": ["event_id", "patch"],
        "properties": {
          "event_id": { "type": "string" },
          "patch": { "type": "object", "additionalProperties": true }
        }
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "op_id": { "type": "string" },
          "event_id": { "type": "string" }
        }
      }
    },
    {
      "name": "calendar.move",
      "method": "POST",
      "endpoint": "/calendar/move",
