{
  "version": "1.0",
  "description": "Tools that the assistant can call on the user's behalf. The backend enforces hard constraints; the model handles OCR, intent, priorities, and soft rules via /policies.",
  "tools": [
    {
      "name": "calendar.freebusy",
      "method": "POST",
      "endpoint": "/calendar/freebusy",
      "input_schema": {
        "type": "object",
        "required": ["start", "end"],
        "properties": {
          "start": { "type": "string", "format": "date-time" },
          "end": { "type": "string", "format": "date-time" }
        }
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "free_windows": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "start": { "type": "string" },
                "end": { "type": "string" }
              }
            }
          },
          "busy_windows": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "start": { "type": "string" },
                "end": { "type": "string" },
                "event_id": { "type": "string" }
              }
            }
          }
        }
      }
    },
    {
      "name": "calendar.list",
      "method": "POST",
      "endpoint": "/calendar/list",
      "input_schema": {
        "type": "object",
        "required": ["start", "end"],
        "properties": {
          "start": { "type": "string", "format": "date-time" },
          "end": { "type": "string", "format": "date-time" },
          "calendar_id": { "type": "string" },
          "limit": { "type": "integer", "minimum": 1, "maximum": 100, "default": 20 }
        }
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "events": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": { "type": "string" },
                "title": { "type": "string" },
                "start": { "type": "string" },
                "end": { "type": "string" },
                "all_day": { "type": "boolean" },
                "location": { "type": "string" },
                "attendees": { "type": "array", "items": { "type": "string" } },
                "priority": { "type": "string" },
                "status": { "type": "string" }
              }
            }
          }
        }
      }
    },
    {
      "name": "calendar.search",
      "method": "POST",
      "endpoint": "/calendar/search",
      "input_schema": {
        "type": "object",
